    "import pandas as pd\n",
    "import os\n",
    "\n",
    "# Path working directory (tempat CSV hasil sebelumnya disimpan)\n",
    "working_path = '/kaggle/working/'\n",
    "\n",
    "# File CSV kanker yang sudah ada (sesuai output-mu)\n",
    "kanker_files = [\n",
    "    working_path + 'fkrtl_kanker.csv',\n",
    "    working_path + 'fktpkapitasi_kanker.csv',\n",
    "    working_path + 'fktpnonkapitasi_kanker.csv'\n",
    "    # Tambah kalau ada varian lain seperti fkrtl_kanker_primer_COO_C97.csv\n",
    "]\n",
    "\n",
    "# Path kepesertaan.dta\n",
    "kep_path = '/kaggle/input/datasets/dewadharmas/dataset/2015202401_kepesertaan.dta'\n",
    "\n",
    "# Step 1: Kumpulkan semua PSTV01 unik dari file kanker\n",
    "peserta_kanker = set()\n",
    "\n",
    "for file in kanker_files:\n",
    "    if os.path.exists(file):\n",
    "        try:\n",
    "            df_temp = pd.read_csv(file, usecols=['PSTV01'], low_memory=False)\n",
    "            unique_ids = df_temp['PSTV01'].astype(str).dropna().unique()\n",
    "            peserta_kanker.update(unique_ids)\n",
    "            print(f\"Dari {os.path.basename(file)}: {len(unique_ids):,} peserta unik\")\n",
    "        except Exception as e:\n",
    "            print(f\"Error baca {os.path.basename(file)}: {str(e)}\")\n",
    "    else:\n",
    "        print(f\"File tidak ditemukan: {file}\")\n",
    "\n",
    "print(f\"\\nTotal peserta unik dengan riwayat kanker (union dari 3 sumber): {len(peserta_kanker):,}\")\n",
    "\n",
    "# Step 2: Filter kepesertaan\n",
    "if os.path.exists(kep_path):\n",
    "    try:\n",
    "        # Baca kepesertaan (hanya kolom penting untuk hemat memori)\n",
    "        kep_cols = ['PSTV01', 'PSTV02', 'PSTV03', 'PSTV04', 'PSTV05', 'PSTV06', 'PSTV07', 'PSTV08', \n",
    "                    'PSTV09', 'PSTV09_NEW', 'PSTV10', 'PSTV11', 'PSTV12', 'PSTV13', 'PSTV13_NEW', \n",
    "                    'PSTV14', 'PSTV15', 'PSTV16', 'PSTV17', 'PSTV18']\n",
    "        \n",
    "        # Coba baca dengan kolom yang ada (jika tidak semua kolom ada)\n",
    "        df_kep = pd.read_stata(kep_path, convert_categoricals=False)\n",
    "        print(\"Shape kepesertaan full:\", df_kep.shape)\n",
    "        \n",
    "        # Filter berdasarkan PSTV01\n",
    "        df_kep_kanker = df_kep[df_kep['PSTV01'].astype(str).isin(peserta_kanker)]\n",
    "        \n",
    "        print(f\"Shape setelah filter peserta kanker: {df_kep_kanker.shape}\")\n",
    "        print(\"Preview 10 baris pertama:\")\n",
    "        display(df_kep_kanker.head(10))\n",
    "        \n",
    "        # Export hasil\n",
    "        output_file = '/kaggle/working/kepesertaan_penderita_kanker.csv'\n",
    "        df_kep_kanker.to_csv(output_file, index=False, encoding='utf-8-sig')\n",
    "        print(f\"\\nHasil final disimpan ke: {output_file}\")\n",
    "        print(\"Download dari sidebar Kaggle → Output → klik kanan → Download\")\n",
    "        \n",
    "    except Exception as e:\n",
    "        print(\"Error proses kepesertaan:\", str(e))\n",
    "else:\n",
    "    print(\"File kepesertaan tidak ditemukan di:\", kep_path)"
