    "import pandas as pd\n",
    "import os\n",
    "\n",
    "base_path = '/kaggle/input/datasets/dewadharmas/dataset/'\n",
    "\n",
    "files = {\n",
    "    'fkrtl'       : '202403_fkrtl.dta',\n",
    "    'fktpkapitasi': '202402_fktpkapitasi.dta',\n",
    "    'nonkapitasi' : '202404_nonkapitasi.dta',\n",
    "    'kepesertaan' : '2015202401_kepesertaan.dta',\n",
    "}\n",
    "\n",
    "rows_var = []   # variable labels\n",
    "rows_val = []   # value labels\n",
    "\n",
    "for name, fname in files.items():\n",
    "    fpath = base_path + fname\n",
    "    if not os.path.exists(fpath):\n",
    "        continue\n",
    "    reader = pd.io.stata.StataReader(fpath)\n",
    "\n",
    "    # Variable labels\n",
    "    for col, label in reader.variable_labels().items():\n",
    "        rows_var.append({\n",
    "            'sumber'     : name,\n",
    "            'kolom_asli' : col,\n",
    "            'kolom_baru' : arti_kolom.get(col, '(belum terdokumentasi)'),\n",
    "            'label_stata': label if label else '(tidak ada label)',\n",
    "        })\n",
    "\n",
    "    # Value labels\n",
    "    for col, mapping in reader.value_labels().items():\n",
    "        for kode, arti in mapping.items():\n",
    "            rows_val.append({\n",
    "                'sumber'     : name,\n",
    "                'kolom_asli' : col,\n",
    "                'kolom_baru' : arti_kolom.get(col, '(belum terdokumentasi)'),\n",
    "                'kode_nilai' : kode,\n",
    "                'arti_nilai' : arti,\n",
    "            })\n",
    "\n",
    "df_var = pd.DataFrame(rows_var)\n",
    "df_val = pd.DataFrame(rows_val)\n",
    "\n",
    "df_var.to_csv('/kaggle/working/task4_variable_labels.csv', index=False, encoding='utf-8-sig')\n",
    "df_val.to_csv('/kaggle/working/task4_value_labels.csv',    index=False, encoding='utf-8-sig')\n",
    "\n",
    "print(f\"Variable labels: {len(df_var)} kolom\")\n",
    "print(f\"Value labels   : {len(df_val)} entri\")\n",
    "print(\"\\nSaved: task4_variable_labels.csv\")\n",
    "print(\"Saved: task4_value_labels.csv\")\n",
    "\n",
    "print(\"\\nPreview variable labels:\")\n",
    "display(df_var.head(20))\n",
    "print(\"\\nPreview value labels:\")\n",
    "display(df_val.head(20))"
   ]
