    "import pandas as pd\n",
    "import os\n",
    "\n",
    "base_path = '/kaggle/input/datasets/dewadharmas/dataset/'\n",
    "\n",
    "files = {\n",
    "    'fkrtl'        : '202403_fkrtl.dta',\n",
    "    'fktpkapitasi' : '202402_fktpkapitasi.dta',\n",
    "    'nonkapitasi'  : '202404_nonkapitasi.dta',\n",
    "    'kepesertaan'  : '2015202401_kepesertaan.dta',\n",
    "}\n",
    "\n",
    "rows = []\n",
    "for name, fname in files.items():\n",
    "    fpath = base_path + fname\n",
    "    if not os.path.exists(fpath):\n",
    "        print(f\"Skip (tidak ditemukan): {fname}\")\n",
    "        continue\n",
    "    df_tmp = pd.read_stata(fpath, convert_categoricals=False)\n",
    "    for col in df_tmp.columns:\n",
    "        s        = df_tmp[col]\n",
    "        n_unique = s.nunique(dropna=True)\n",
    "        n_miss   = s.isna().sum()\n",
    "        sample   = s.dropna().unique()[:5].tolist()\n",
    "        is_dummy = (\n",
    "            (s.dtype == object and 2 <= n_unique <= 20) or\n",
    "            (pd.api.types.is_numeric_dtype(s) and 2 <= n_unique <= 10)\n",
    "        )\n",
    "        rows.append({\n",
    "            'sumber'         : name,\n",
    "            'kolom_asli'     : col,\n",
    "            'kolom_baru'     : arti_kolom.get(col, '(belum terdokumentasi)'),\n",
    "            'tipe_data'      : str(s.dtype),\n",
    "            'n_unik'         : n_unique,\n",
    "            'n_missing'      : n_miss,\n",
    "            'pct_missing'    : f\"{n_miss/len(df_tmp)*100:.1f}%\",\n",
    "            'contoh_nilai'   : str(sample),\n",
    "            'kandidat_dummy' : 'YA' if is_dummy else '',\n",
    "        })\n",
    "\n",
    "df_task4 = pd.DataFrame(rows)\n",
    "df_task4.to_csv('/kaggle/working/task4_data_dictionary.csv', index=False, encoding='utf-8-sig')\n",
    "print(f\"Total kolom terdokumentasi: {len(df_task4)}\")\n",
    "print(\"\\nKandidat dummy coding:\")\n",
    "display(df_task4[df_task4['kandidat_dummy']=='YA'][\n",
    "    ['sumber','kolom_asli','kolom_baru','n_unik','contoh_nilai']\n",
    "])\n",
    "print(\"Saved: task4_data_dictionary.csv\")"
   ]
