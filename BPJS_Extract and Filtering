    "import pandas as pd\n",
    "\n",
    "# Path file kamu (sudah fix dari ls sebelumnya)\n",
    "file_path = '/kaggle/input/datasets/dewadharmas/dataset/202403_fkrtl.dta'\n",
    "\n",
    "# Baca file (pakai convert_categoricals=False supaya kode tetap string asli, tidak jadi category)\n",
    "df = pd.read_stata(file_path, convert_categoricals=False)\n",
    "\n",
    "# Setting Pandas supaya semua kolom tampil tanpa dipotong (...), lebar cukup\n",
    "pd.set_option('display.max_columns', None)\n",
    "pd.set_option('display.max_colwidth', 150)      # naikkan kalau kode/deskripsi panjang\n",
    "pd.set_option('display.width', 1000)            # biar horizontal scroll muncul kalau perlu\n",
    "pd.set_option('display.expand_frame_repr', False)\n",
    "\n",
    "# Pastikan kolom FKL15A jadi string bersih (trim spasi, uppercase biar konsisten)\n",
    "df['FKL15A'] = df['FKL15A'].astype(str).str.strip().str.upper()\n",
    "\n",
    "# Filter: FKL15A antara C00 sampai C97 (inklusif)\n",
    "# Versi ketat: hanya kode tepat 3 karakter (C + 2 digit)\n",
    "df_kanker = df[\n",
    "    (df['FKL15A'] >= 'C00') & \n",
    "    (df['FKL15A'] <= 'C97') &\n",
    "    (df['FKL15A'].str.len() == 3) &               # kalau kode panjang seperti C509, hapus baris ini\n",
    "    (df['FKL15A'].str[0] == 'C')\n",
    "].copy()\n",
    "\n",
    "# Kalau kode diagnosis bisa lebih panjang (C509, C34.9, C5090, dll), pakai versi ini saja:\n",
    "# df_kanker = df[df['FKL15A'].str.startswith('C', na=False)]\n",
    "\n",
    "# Tampilkan hasil\n",
    "print(f\"Jumlah baris setelah filter (hanya diagnosis primer C00-C97): {len(df_kanker):,}\")\n",
    "print(f\"Shape: {df_kanker.shape}\")\n",
    "print(\"\\nSemua kolom yang ditampilkan:\")\n",
    "print(df_kanker.columns.tolist())\n",
    "\n",
    "# Tampilkan full hasil filter (semua kolom, tapi batasi jumlah baris supaya tidak crash)\n",
    "# Ubah .head(50) jadi .head(200) atau lebih kalau mau lihat lebih banyak\n",
    "print(\"\\nPreview hasil filter (semua kolom, 50 baris pertama):\")\n",
    "display(df_kanker.head(50))\n",
    "\n",
    "# Kalau mau simpan hasilnya ke CSV (bisa download dari Kaggle)\n",
    "df_kanker.to_csv('/kaggle/working/fkrtl_kanker_primer_C00_C97.csv', \n",
    "                 index=False, \n",
    "                 encoding='utf-8-sig')\n",
    "print(\"Hasil sudah disimpan ke: /kaggle/working/fkrtl_kanker_primer_C00_C97.csv\")"
   ]
