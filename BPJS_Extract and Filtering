    "# ================================================================\n",
    "# MASTER MAPPING KOLOM BPJS\n",
    "# Sumber: Dokumen Pengantar Data Sampel BPJS Kesehatan\n",
    "# ================================================================\n",
    "\n",
    "arti_kolom = {\n",
    "    # ── KEPESERTAAN (PSTV) ──────────────────────────────────────\n",
    "    'PSTV01'     : 'no_peserta',\n",
    "    'PSTV02'     : 'id_keluarga',\n",
    "    'PSTV03'     : 'kode_fktp_daftar',\n",
    "    'PSTV04'     : 'tahun_kepesertaan',\n",
    "    'PSTV05'     : 'jenis_kelamin',           # 1=Laki-laki, 2=Perempuan\n",
    "    'PSTV06'     : 'tanggal_lahir',\n",
    "    'PSTV07'     : 'usia',\n",
    "    'PSTV08'     : 'jenis_peserta',           # PPU/PBI/PBPU/BP/PBI APBD\n",
    "    'PSTV09'     : 'kode_kabupaten',\n",
    "    'PSTV09_NEW' : 'kode_kabupaten_baru',\n",
    "    'PSTV10'     : 'kode_provinsi',\n",
    "    'PSTV11'     : 'status_aktif',\n",
    "    'PSTV12'     : 'tanggal_mulai_aktif',\n",
    "    'PSTV13'     : 'tanggal_akhir_aktif',\n",
    "    'PSTV13_NEW' : 'tanggal_akhir_aktif_baru',\n",
    "    'PSTV14'     : 'strata_sampling',\n",
    "    'PSTV15'     : 'bobot_individu',\n",
    "    'PSTV16'     : 'bobot_keluarga',\n",
    "    'PSTV17'     : 'jumlah_anggota_keluarga',\n",
    "    'PSTV18'     : 'kategori_keluarga',\n",
    "\n",
    "    # ── FKRTL (FKL) ─────────────────────────────────────────────\n",
    "    'FKL01'  : 'no_peserta',\n",
    "    'FKL02'  : 'id_kunjungan',\n",
    "    'FKL03'  : 'tanggal_kunjungan',\n",
    "    'FKL04'  : 'kode_faskes',\n",
    "    'FKL05'  : 'jenis_faskes',\n",
    "    'FKL06'  : 'kode_ppk_perujuk',\n",
    "    'FKL07'  : 'jenis_rujukan',\n",
    "    'FKL08'  : 'tanggal_masuk',\n",
    "    'FKL09'  : 'tanggal_keluar',\n",
    "    'FKL10'  : 'tingkat_pelayanan',           # RJTL=Rawat Jalan, RITL=Rawat Inap\n",
    "    'FKL11'  : 'kelas_rawat',\n",
    "    'FKL12'  : 'lama_rawat',\n",
    "    'FKL13'  : 'cara_keluar',\n",
    "    'FKL14'  : 'kondisi_keluar',\n",
    "    'FKL15'  : 'kode_diagnosis_primer',\n",
    "    'FKL15A' : 'diagnosis_primer',            # kode ICD-10\n",
    "    'FKL16'  : 'kode_diagnosis_sekunder_1',\n",
    "    'FKL16A' : 'diagnosis_sekunder_1',\n",
    "    'FKL17'  : 'kode_diagnosis_sekunder_2',\n",
    "    'FKL17A' : 'diagnosis_sekunder_2',\n",
    "    'FKL18'  : 'kode_diagnosis_sekunder_3',\n",
    "    'FKL18A' : 'diagnosis_sekunder_3',\n",
    "    'FKL19'  : 'kode_diagnosis_sekunder_4',\n",
    "    'FKL19A' : 'diagnosis_sekunder_4',\n",
    "    'FKL20'  : 'biaya_total',\n",
    "    'FKL21'  : 'biaya_obat',\n",
    "    'FKL22'  : 'biaya_tindakan',\n",
    "    'FKL23'  : 'biaya_akomodasi',\n",
    "    'FKL24'  : 'tarif_ina_cbg',\n",
    "    'FKL25'  : 'kode_ina_cbg',\n",
    "    'FKL26'  : 'nama_ina_cbg',\n",
    "\n",
    "    # ── FKTP KAPITASI (FKP) ──────────────────────────────────────\n",
    "    'FKP01'  : 'no_peserta',\n",
    "    'FKP02'  : 'id_kunjungan',\n",
    "    'FKP03'  : 'tanggal_kunjungan',\n",
    "    'FKP04'  : 'kode_fktp',\n",
    "    'FKP05'  : 'jenis_kunjungan',\n",
    "    'FKP06'  : 'jenis_pelayanan',\n",
    "    'FKP07'  : 'kode_dokter',\n",
    "    'FKP08'  : 'spesialisasi_dokter',\n",
    "    'FKP09'  : 'kode_tindakan',\n",
    "    'FKP10'  : 'nama_tindakan',\n",
    "    'FKP11'  : 'biaya_tindakan',\n",
    "    'FKP12'  : 'biaya_total',\n",
    "    'FKP13'  : 'status_kunjungan',\n",
    "    'FKP14'  : 'kode_diagnosis',\n",
    "    'FKP14A' : 'diagnosis_primer',            # kode ICD-10\n",
    "    'FKP15'  : 'diagnosis_sekunder',\n",
    "\n",
    "    # ── FKTP NON KAPITASI (PNK) ──────────────────────────────────\n",
    "    'PNK01'  : 'no_peserta',\n",
    "    'PNK02'  : 'id_kunjungan',\n",
    "    'PNK03'  : 'tanggal_kunjungan',\n",
    "    'PNK04'  : 'kode_faskes',\n",
    "    'PNK05'  : 'jenis_pelayanan',\n",
    "    'PNK06'  : 'kode_tindakan',\n",
    "    'PNK07'  : 'nama_tindakan',\n",
    "    'PNK08'  : 'biaya_tindakan',\n",
    "    'PNK09'  : 'biaya_total',\n",
    "    'PNK10'  : 'status_kunjungan',\n",
    "    'PNK11'  : 'kode_dokter',\n",
    "    'PNK12'  : 'spesialisasi_dokter',\n",
    "    'PNK13'  : 'tanggal_pelayanan',\n",
    "    'PNK14'  : 'diagnosis_primer',            # kode ICD-10\n",
    "}\n",
    "\n",
    "def rename_cols(df):\n",
    "    \"\"\"Rename semua kolom yang ada di mapping. Kolom lain tetap nama asli.\"\"\"\n",
    "    return df.rename(columns={k: v for k, v in arti_kolom.items() if k in df.columns})\n",
    "\n",
    "print(f\"Master mapping siap: {len(arti_kolom)} kolom terdefinisi.\")\n",
    "print(\"Fungsi rename_cols() siap digunakan.\")"
