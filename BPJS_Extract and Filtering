    "import pandas as pd\n",
    "import os\n",
    "\n",
    "icd_path = '/kaggle/input/datasets/dewadharmas/icd10meryn/'\n",
    "\n",
    "# Cek file yang tersedia\n",
    "print(\"File ICD-10 tersedia:\")\n",
    "for f in os.listdir(icd_path):\n",
    "    size = os.path.getsize(os.path.join(icd_path, f)) / 1024\n",
    "    print(f\"  {f:50s} {size:.1f} KB\")\n",
    "\n",
    "# Baca semua file ICD-10\n",
    "icd_files = [\n",
    "    'icd10_info.dta',\n",
    "    'icd10_info_dxmasuk.dta',\n",
    "    'icd10_info_dxprimer.dta',\n",
    "    'icd10_info_pnk.dta',\n",
    "]\n",
    "\n",
    "for fname in icd_files:\n",
    "    fpath = icd_path + fname\n",
    "    if not os.path.exists(fpath):\n",
    "        continue\n",
    "    print(f\"\\n=== {fname} ===\")\n",
    "    df_icd = pd.read_stata(fpath, convert_categoricals=False)\n",
    "    print(f\"Shape : {df_icd.shape}\")\n",
    "    print(f\"Kolom : {df_icd.columns.tolist()}\")\n",
    "    display(df_icd.head(10))"
   ]
