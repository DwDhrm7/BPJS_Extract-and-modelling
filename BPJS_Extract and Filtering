    "import pandas as pd\n",
    "\n",
    "base_path = '/kaggle/input/datasets/dewadharmas/dataset/'\n",
    "\n",
    "# Load task1\n",
    "df_task1 = pd.read_csv('/kaggle/working/task1_fkrtl_C53_C56.csv', low_memory=False)\n",
    "peserta_set = set(df_task1['no_peserta'].astype(str).dropna().unique())\n",
    "print(f\"Peserta unik dari Task 1: {len(peserta_set):,}\")\n",
    "\n",
    "# Baca kepesertaan\n",
    "df_kep = pd.read_stata(base_path + '2015202401_kepesertaan.dta', convert_categoricals=False)\n",
    "print(f\"Shape kepesertaan: {df_kep.shape}\")\n",
    "\n",
    "# Rename dulu kepesertaan\n",
    "df_kep = rename_cols(df_kep)\n",
    "\n",
    "# Samakan tipe sebelum merge\n",
    "df_task1['no_peserta'] = df_task1['no_peserta'].astype(str)\n",
    "df_kep['no_peserta']   = df_kep['no_peserta'].astype(str)\n",
    "\n",
    "# Filter kepesertaan\n",
    "df_task2_kep = df_kep[df_kep['no_peserta'].isin(peserta_set)].copy()\n",
    "print(f\"Kepesertaan match: {len(df_task2_kep):,}\")\n",
    "\n",
    "# Merge\n",
    "df_task2_combined = df_task1.merge(df_task2_kep, on='no_peserta', how='left')\n",
    "print(f\"Shape combined: {df_task2_combined.shape}\")\n",
    "\n",
    "# Ringkasan match\n",
    "n_match    = df_task2_kep['no_peserta'].nunique()\n",
    "n_no_match = len(peserta_set) - n_match\n",
    "print(f\"\\n=== Ringkasan ===\")\n",
    "print(f\"Peserta unik FKRTL C53-C56 : {len(peserta_set):,}\")\n",
    "print(f\"Match di kepesertaan        : {n_match:,}\")\n",
    "print(f\"Tidak match                 : {n_no_match:,}\")\n",
    "print(f\"Match rate                  : {n_match/len(peserta_set)*100:.2f}%\")\n",
    "\n",
    "# Simpan\n",
    "df_task2_kep.to_csv('/kaggle/working/task2_kepesertaan_C53_C56.csv', index=False, encoding='utf-8-sig')\n",
