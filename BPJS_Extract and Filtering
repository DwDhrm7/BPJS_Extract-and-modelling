    "import pandas as pd\n",
    "import glob\n",
    "import os\n",
    "\n",
    "# Path dasar dataset kamu\n",
    "base_path = '/kaggle/input/datasets/dewadharmas/dataset/'\n",
    "\n",
    "# Path lengkap file (pakai nama persis dari list kamu)\n",
    "fkrtl_path     = base_path + '202403_fkrtl.dta'\n",
    "fktp_kap_path  = base_path + '202402_fktpkapitasi.dta'\n",
    "fktp_non_path  = base_path + '202404_nonkapitasi.dta'\n",
    "\n",
    "# Fungsi filter kanker (mulai 'C' di salah satu kolom diagnosis primer)\n",
    "def filter_kanker(df, diag_cols):\n",
    "    mask = pd.Series(False, index=df.index)\n",
    "    used_cols = []\n",
    "    \n",
    "    for col in diag_cols:\n",
    "        if col in df.columns:\n",
    "            df[col] = df[col].astype(str).str.strip().str.upper()\n",
    "            mask |= df[col].str.startswith('C', na=False)\n",
    "            used_cols.append(col)\n",
    "    \n",
    "    if used_cols:\n",
    "        df_filtered = df[mask].copy()\n",
    "        return df_filtered, used_cols\n",
    "    else:\n",
    "        print(f\"Kolom diagnosis tidak ditemukan. Dicoba: {diag_cols}\")\n",
    "        return pd.DataFrame(), []\n",
    "\n",
    "# 1. FKRTL\n",
    "print(\"\\n=== FKRTL (202403_fkrtl.dta) ===\")\n",
    "if os.path.exists(fkrtl_path):\n",
    "    try:\n",
    "        df_fkrtl = pd.read_stata(fkrtl_path, convert_categoricals=False)\n",
    "        print(\"Shape:\", df_fkrtl.shape)\n",
    "        df_fkrtl_kanker, used = filter_kanker(df_fkrtl, ['FKL15A', 'FKL15'])\n",
    "        print(f\"Kolom diagnosis digunakan: {used}\")\n",
    "        print(f\"Jumlah baris kanker: {len(df_fkrtl_kanker):,}\")\n",
    "        if not df_fkrtl_kanker.empty:\n",
    "            display(df_fkrtl_kanker.head(10))\n",
    "            df_fkrtl_kanker.to_csv('/kaggle/working/fkrtl_kanker.csv', index=False, encoding='utf-8-sig')\n",
    "            print(\"→ Disimpan: /kaggle/working/fkrtl_kanker.csv\")\n",
    "        else:\n",
    "            print(\"Tidak ada baris kanker di FKRTL\")\n",
    "    except Exception as e:\n",
    "        print(\"Error FKRTL:\", str(e))\n",
    "else:\n",
    "    print(\"File FKRTL tidak ditemukan di:\", fkrtl_path)\n",
    "\n",
    "# 2. FKTP Kapitasi\n",
    "print(\"\\n=== FKTP Kapitasi (202402_fktpkapitasi.dta) ===\")\n",
    "if os.path.exists(fktp_kap_path):\n",
    "    try:\n",
    "        df_kap = pd.read_stata(fktp_kap_path, convert_categoricals=False)\n",
    "        print(\"Shape:\", df_kap.shape)\n",
    "        df_kap_kanker, used = filter_kanker(df_kap, ['FKP14A', 'FKP15'])\n",
    "        print(f\"Kolom diagnosis digunakan: {used}\")\n",
    "        print(f\"Jumlah baris kanker: {len(df_kap_kanker):,}\")\n",
    "        if not df_kap_kanker.empty:\n",
    "            display(df_kap_kanker.head(10))\n",
    "            df_kap_kanker.to_csv('/kaggle/working/fktpkapitasi_kanker.csv', index=False, encoding='utf-8-sig')\n",
    "            print(\"→ Disimpan: /kaggle/working/fktpkapitasi_kanker.csv\")\n",
    "        else:\n",
    "            print(\"Tidak ada baris kanker di FKTP Kapitasi\")\n",
    "    except Exception as e:\n",
    "        print(\"Error FKTP Kapitasi:\", str(e))\n",
    "else:\n",
    "    print(\"File FKTP Kapitasi tidak ditemukan di:\", fktp_kap_path)\n",
    "\n",
    "# 3. FKTP Non Kapitasi\n",
    "print(\"\\n=== FKTP Non Kapitasi (202404_nonkapitasi.dta) ===\")\n",
    "if os.path.exists(fktp_non_path):\n",
    "    try:\n",
    "        df_non = pd.read_stata(fktp_non_path, convert_categoricals=False)\n",
    "        print(\"Shape:\", df_non.shape)\n",
    "        df_non_kanker, used = filter_kanker(df_non, ['PNK14'])\n",
    "        print(f\"Kolom diagnosis digunakan: {used}\")\n",
    "        print(f\"Jumlah baris kanker: {len(df_non_kanker):,}\")\n",
    "        if not df_non_kanker.empty:\n",
    "            display(df_non_kanker.head(10))\n",
    "            df_non_kanker.to_csv('/kaggle/working/fktpnonkapitasi_kanker.csv', index=False, encoding='utf-8-sig')\n",
    "            print(\"→ Disimpan: /kaggle/working/fktpnonkapitasi_kanker.csv\")\n",
    "        else:\n",
    "            print(\"Tidak ada baris kanker di FKTP Non Kapitasi\")\n",
    "    except Exception as e:\n",
    "        print(\"Error FKTP Non Kapitasi:\", str(e))\n",
    "else:\n",
    "    print(\"File FKTP Non Kapitasi tidak ditemukan di:\", fktp_non_path)"
