    "import pandas as pd\n",
    "\n",
    "# Path dasar dataset-mu (sudah fix)\n",
    "base_path = '/kaggle/input/datasets/dewadharmas/dataset/'\n",
    "\n",
    "# Dictionary file yang mau diexport\n",
    "files_to_export = {\n",
    "    'fkrtl': '202403_fkrtl.dta',\n",
    "    'fktpkapitasi': '202402_fktpkapitasi.dta',\n",
    "    'nonkapitasi': '202404_nonkapitasi.dta'\n",
    "}\n",
    "\n",
    "for name, filename in files_to_export.items():\n",
    "    full_path = base_path + filename\n",
    "    output_csv = f'/kaggle/working/{name}_full.csv'\n",
    "    \n",
    "    print(f\"\\n=== Memproses {filename} ===\")\n",
    "    try:\n",
    "        # Baca file .dta (tanpa filter, tanpa sort, full isi)\n",
    "        df = pd.read_stata(full_path, convert_categoricals=False)\n",
    "        \n",
    "        print(f\"Shape: {df.shape[0]:,} baris x {df.shape[1]} kolom\")\n",
    "        print(f\"Memory usage approx: {df.memory_usage(deep=True).sum() / (1024**2):.2f} MB\")\n",
    "        print(\"Kolom pertama (sample):\", df.columns.tolist()[:15])\n",
    "        \n",
    "        # Export full ke CSV (tanpa index, encoding bagus untuk Excel Indo)\n",
    "        df.to_csv(output_csv, index=False, encoding='utf-8-sig')\n",
    "        print(f\"→ Berhasil diekspor ke: {output_csv}\")\n",
    "        print(\"Cara download: Sidebar Kaggle → Output → klik kanan file → Download\")\n",
    "        \n",
    "    except FileNotFoundError:\n",
    "        print(f\"File tidak ditemukan: {full_path}\")\n",
    "        print(\"Pastikan dataset sudah di-add ke notebook dan nama file persis sama (case-sensitive).\")\n",
    "    except MemoryError:\n",
    "        print(\"MemoryError: File terlalu besar untuk dibaca full sekaligus.\")\n",
    "        print(\"Solusi: Kita bisa baca per chunk atau export kolom tertentu saja. Kasih tahu kalau ini terjadi.\")\n",
    "    except Exception as e:\n",
    "        print(f\"Error saat proses {name}: {str(e)}\")"
   ]
