    "import pandas as pd\n",
    "import os\n",
    "\n",
    "base_path    = '/kaggle/input/datasets/dewadharmas/dataset/'\n",
    "working_path = '/kaggle/working/'\n",
    "\n",
    "# Kumpulkan PSTV01 dari semua file kanker yang sudah ada\n",
    "kanker_files = {\n",
    "    'fkrtl'       : working_path + 'fkrtl_kanker.csv',\n",
    "    'fktpkapitasi': working_path + 'fktpkapitasi_kanker.csv',\n",
    "    'nonkapitasi' : working_path + 'nonkapitasi_kanker.csv',\n",
    "}\n",
    "\n",
    "# Kolom no_peserta sudah di-rename\n",
    "peserta_kanker = set()\n",
    "for name, fpath in kanker_files.items():\n",
    "    if os.path.exists(fpath):\n",
    "        df_tmp = pd.read_csv(fpath, usecols=['no_peserta'], low_memory=False)\n",
    "        ids    = df_tmp['no_peserta'].astype(str).dropna().unique()\n",
    "        peserta_kanker.update(ids)\n",
    "        print(f\"{name}: {len(ids):,} peserta unik\")\n",
    "    else:\n",
    "        print(f\"File tidak ditemukan: {fpath} (jalankan Cell 2 dulu)\")\n",
    "\n",
    "print(f\"\\nTotal peserta unik gabungan: {len(peserta_kanker):,}\")\n",
    "\n",
    "# Filter kepesertaan\n",
    "kep_path = base_path + '2015202401_kepesertaan.dta'\n",
    "df_kep   = pd.read_stata(kep_path, convert_categoricals=False)\n",
    "df_kep   = rename_cols(df_kep)\n",
    "df_kep['no_peserta'] = df_kep['no_peserta'].astype(str)\n",
    "\n",
    "df_kep_kanker = df_kep[df_kep['no_peserta'].isin(peserta_kanker)].copy()\n",
    "print(f\"Shape kepesertaan penderita kanker: {df_kep_kanker.shape}\")\n",
    "\n",
    "df_kep_kanker.to_csv(working_path + 'kepesertaan_penderita_kanker_all.csv', index=False, encoding='utf-8-sig')\n",
    "print(\"Saved: kepesertaan_penderita_kanker_all.csv\")\n",
    "display(df_kep_kanker.head(10))"
